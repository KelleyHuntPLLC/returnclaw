# ============================================
# ReturnClaw Environment Configuration
# ============================================

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://returnclaw:returnclaw@localhost:5432/returnclaw
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rc:

# Authentication
JWT_SECRET=change-me-to-a-random-256-bit-key
JWT_EXPIRES_IN=7d
JWT_ISSUER=returnclaw

# Encryption (for storing OAuth tokens, etc.)
ENCRYPTION_KEY=change-me-to-a-random-256-bit-hex-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# OpenAI Realtime API (Voice)
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Carrier APIs
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
USPS_API_KEY=

# Google Maps (for drop-off location search)
GOOGLE_MAPS_API_KEY=

# Email OAuth (Gmail)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/callback/gmail

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS
CORS_ORIGIN=http://localhost:3001

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=returnclaw-gateway
