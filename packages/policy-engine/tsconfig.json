{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@returnclaw/core": ["../core/src"],
      "@returnclaw/core/*": ["../core/src/*"],
      "@returnclaw/agents": ["../agents/src"],
      "@returnclaw/agents/*": ["../agents/src/*"],
      "@returnclaw/policy-engine": ["../policy-engine/src"],
      "@returnclaw/policy-engine/*": ["../policy-engine/src/*"],
      "@returnclaw/carriers": ["../carriers/src"],
      "@returnclaw/carriers/*": ["../carriers/src/*"],
      "@returnclaw/email-parser": ["../email-parser/src"],
      "@returnclaw/email-parser/*": ["../email-parser/src/*"],
      "@returnclaw/voice": ["../voice/src"],
      "@returnclaw/voice/*": ["../voice/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
